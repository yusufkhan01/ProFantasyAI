# Comma-separated list of origins allowed by CORS (your deployed frontend URL).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upstream FPL API base URL (rarely needs changing).
FPL_BASE_URL=https://fantasy.premierleague.com/api

# How long (seconds) to cache FPL responses before refetching.
CACHE_TTL_SECONDS=900
